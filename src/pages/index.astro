---
import Layout from '../layouts/Layout.astro';

const surfaces = [
  {
    title: 'Super-Tenant API',
    description: 'Cross-tenant operations for partners building shipped integrations (Nango connectors, Marketplace bundles, automation tooling).',
    gradient: 'linear-gradient(135deg, #0074FF 0%, #3BFFBF 100%)',
    icon: 'M13 2L3 14h9l-1 8 10-12h-9l1-8z',
  },
  {
    title: 'Marketplace bundle authoring',
    description: 'Publish a bundle of skills, knowledge, and procedures to the TrainAR Marketplace and earn revenue from every subscribing tenant.',
    gradient: 'linear-gradient(135deg, #3BFFBF 0%, #0074FF 100%)',
    icon: 'M3 3h7v7H3zM14 3h7v7h-7zM14 14h7v7h-7zM3 14h7v7H3z',
  },
  {
    title: 'Nango connector contribution',
    description: 'Add support for a new field-service or CRM system to TrainAR by contributing a connector via the Nango ecosystem.',
    gradient: 'linear-gradient(135deg, #0074FF 0%, #121621 100%)',
    icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01z',
  },
  {
    title: 'Curator program',
    description: 'The economic model behind publishing on the Marketplace. Pricing, fee structure, payout cadence, exclusivity options.',
    gradient: 'linear-gradient(135deg, #121621 0%, #0074FF 100%)',
    icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01z',
  },
  {
    title: 'Platform-skill spec',
    description: 'Calling conventions, response_target options, display hints, voice patterns, orchestration rules for skills you author at platform level.',
    gradient: 'linear-gradient(135deg, #0074FF 0%, #3BFFBF 100%)',
    icon: 'M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z',
  },
];
---

<Layout
  title="TrainAR Developers — Build on TrainAR"
  description="Build on TrainAR. Partner integrations, Marketplace bundles, curator economics, platform-skill authoring."
  canonicalPath="/"
>
  <section class="border-b border-[#E2E8F0] bg-gradient-to-b from-white to-[#F7FAFC]">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
      <div class="max-w-3xl">
        <span class="inline-flex items-center rounded-full bg-[#E8F2FF] px-3 py-1 text-xs font-bold uppercase tracking-widest text-[#0074FF]">For partners + builders</span>
        <h1 class="mt-5 font-[var(--font-display)] text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tight text-[#121621] uppercase leading-[1.0]">
          Build on<br />TrainAR
        </h1>
        <p class="mt-6 text-lg sm:text-xl text-[#4B5563] max-w-2xl leading-relaxed">
          The developer surface for partners shipping integrations, curators publishing bundles, and platform engineers authoring skills the on-glasses AI calls in real time.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="/request-access"
            class="inline-flex items-center rounded-[12px] px-5 py-3 text-sm font-semibold text-white shadow-[0_4px_20px_hsla(212,100%,50%,0.15)] hover:shadow-[0_8px_30px_hsla(212,100%,50%,0.20)] transition-all"
            style="background: linear-gradient(180deg, #0074FF 0%, #005FD1 100%);"
          >
            Request access
          </a>
          <a
            href="https://docs.trainar.ai/developer/"
            class="inline-flex items-center rounded-[12px] px-5 py-3 text-sm font-semibold text-[#121621] bg-white border border-[#E2E8F0] hover:bg-[#F7FAFC] transition"
          >
            Tenant API docs →
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
    <div class="max-w-3xl mb-10">
      <h2 class="font-[var(--font-display)] text-3xl sm:text-4xl font-bold tracking-tight text-[#121621] uppercase">What's available</h2>
      <p class="mt-4 text-base text-[#4B5563]">Five surfaces. All gated. Access is granted on request after a short review — we keep the partner ecosystem small and intentional.</p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {surfaces.map((s) => (
        <a href="/request-access" class="group rounded-2xl border border-[#E2E8F0] bg-white p-6 hover:border-[#0074FF] hover:shadow-[0_8px_30px_rgba(0,116,255,0.10)] transition-all">
          <div
            class="inline-flex h-11 w-11 items-center justify-center rounded-xl text-white"
            style={`background: ${s.gradient};`}
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d={s.icon}></path>
            </svg>
          </div>
          <h3 class="mt-5 font-[var(--font-display)] text-xl font-bold uppercase tracking-tight text-[#121621]">{s.title}</h3>
          <p class="mt-2 text-sm text-[#4B5563] leading-relaxed">{s.description}</p>
          <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-[#0074FF] group-hover:gap-2 transition-all">
            Request access →
          </span>
        </a>
      ))}
    </div>
  </section>

  <section class="border-t border-[#E2E8F0] bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
      <div class="grid gap-10 lg:grid-cols-2 lg:items-center">
        <div>
          <h2 class="font-[var(--font-display)] text-3xl sm:text-4xl font-bold tracking-tight text-[#121621] uppercase">Already a tenant?</h2>
          <p class="mt-4 text-base text-[#4B5563] max-w-xl leading-relaxed">
            If you're a TrainAR customer building automation for your <strong>own</strong> tenant — wiring sessions into your Zapier, n8n, or Make flows — you don't need access here. Use the Tenant API, MCP server, and webhooks from your account.
          </p>
          <a href="https://docs.trainar.ai/developer/" class="mt-6 inline-flex items-center gap-1 text-sm font-semibold text-[#0074FF] hover:gap-2 transition-all">
            Tenant API docs on docs.trainar.ai →
          </a>
        </div>
        <div>
          <h2 class="font-[var(--font-display)] text-3xl sm:text-4xl font-bold tracking-tight text-[#121621] uppercase">Why gated?</h2>
          <p class="mt-4 text-base text-[#4B5563] max-w-xl leading-relaxed">
            Partner integrations carry trust. A Marketplace bundle becomes part of every subscriber's training. A Nango connector ships under our name. A platform skill runs on every engineer's glasses. We review each application personally so the partner ecosystem stays small, intentional, and high-quality.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-[#E2E8F0]">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
      <div class="max-w-3xl mb-10">
        <span class="inline-flex items-center rounded-full bg-[#E8F2FF] px-3 py-1 text-xs font-bold uppercase tracking-widest text-[#0074FF]">How partners build with us</span>
        <h2 class="mt-5 font-[var(--font-display)] text-3xl sm:text-4xl font-bold tracking-tight text-[#121621] uppercase">Staging first, then production</h2>
        <p class="mt-4 text-base text-[#4B5563] leading-relaxed">Same pattern as Stripe's test mode → live mode. You build and prove your integration against an isolated environment; we promote you to production once it's reviewed.</p>
      </div>
      <div class="grid gap-6 md:grid-cols-3">
        <div class="rounded-2xl bg-white border border-[#E2E8F0] p-6">
          <div class="text-xs font-bold uppercase tracking-widest text-[#0074FF]">Step 1</div>
          <h3 class="mt-3 font-[var(--font-display)] text-xl font-bold uppercase tracking-tight text-[#121621]">Apply</h3>
          <p class="mt-2 text-sm text-[#4B5563] leading-relaxed">Submit the request-access form. Tell us what you're building, who it's for, how you'll distribute it. We respond within 3 business days.</p>
        </div>
        <div class="rounded-2xl bg-white border border-[#E2E8F0] p-6">
          <div class="text-xs font-bold uppercase tracking-widest text-[#0074FF]">Step 2</div>
          <h3 class="mt-3 font-[var(--font-display)] text-xl font-bold uppercase tracking-tight text-[#121621]">Build on staging</h3>
          <p class="mt-2 text-sm text-[#4B5563] leading-relaxed">Approved partners get a staging tenant + scoped staging tokens. Build and test against an isolated environment that mirrors production. No customer data at risk.</p>
        </div>
        <div class="rounded-2xl bg-white border border-[#E2E8F0] p-6">
          <div class="text-xs font-bold uppercase tracking-widest text-[#0074FF]">Step 3</div>
          <h3 class="mt-3 font-[var(--font-display)] text-xl font-bold uppercase tracking-tight text-[#121621]">Promote to prod</h3>
          <p class="mt-2 text-sm text-[#4B5563] leading-relaxed">Once we've reviewed your integration end-to-end on staging, we promote: your bundle or connector ships to production, and you get prod-scoped tokens if your integration needs them.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
