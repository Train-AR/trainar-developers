---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Request developer access — TrainAR Developers"
  description="Apply for access to TrainAR's gated developer surface — Super-Tenant API, Marketplace bundle authoring, Nango connectors, curator program, platform skills."
  canonicalPath="/request-access"
>
  <section class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
    <a href="/" class="inline-flex items-center gap-1 text-sm text-[#4B5563] hover:text-[#121621] transition mb-6">← Back to home</a>
    <span class="inline-flex items-center rounded-full bg-[#E8F2FF] px-3 py-1 text-xs font-bold uppercase tracking-widest text-[#0074FF]">Request access</span>
    <h1 class="mt-5 font-[var(--font-display)] text-4xl sm:text-5xl font-bold tracking-tight text-[#121621] uppercase leading-[1.0]">
      Tell us what you're<br />building
    </h1>
    <p class="mt-5 text-lg text-[#4B5563] max-w-2xl leading-relaxed">
      Applications are reviewed personally. We respond within 3 business days.
    </p>

    <form id="access-form" class="mt-10 space-y-6 bg-white border border-[#E2E8F0] rounded-2xl p-6 sm:p-8">
      <div class="grid sm:grid-cols-2 gap-6">
        <label class="block">
          <span class="text-sm font-semibold text-[#121621]">Your name</span>
          <input
            type="text"
            name="name"
            required
            class="mt-2 block w-full rounded-lg border border-[#E2E8F0] bg-white px-4 py-2.5 text-sm text-[#121621] focus:border-[#0074FF] focus:ring-2 focus:ring-[#0074FF]/20 outline-none transition"
          />
        </label>
        <label class="block">
          <span class="text-sm font-semibold text-[#121621]">Work email</span>
          <input
            type="email"
            name="email"
            required
            class="mt-2 block w-full rounded-lg border border-[#E2E8F0] bg-white px-4 py-2.5 text-sm text-[#121621] focus:border-[#0074FF] focus:ring-2 focus:ring-[#0074FF]/20 outline-none transition"
          />
        </label>
      </div>

      <label class="block">
        <span class="text-sm font-semibold text-[#121621]">Company or organisation</span>
        <input
          type="text"
          name="company"
          required
          class="mt-2 block w-full rounded-lg border border-[#E2E8F0] bg-white px-4 py-2.5 text-sm text-[#121621] focus:border-[#0074FF] focus:ring-2 focus:ring-[#0074FF]/20 outline-none transition"
        />
      </label>

      <label class="block">
        <span class="text-sm font-semibold text-[#121621]">What are you planning to build?</span>
        <select
          name="surface"
          required
          class="mt-2 block w-full rounded-lg border border-[#E2E8F0] bg-white px-4 py-2.5 text-sm text-[#121621] focus:border-[#0074FF] focus:ring-2 focus:ring-[#0074FF]/20 outline-none transition"
        >
          <option value="">Choose one…</option>
          <option value="marketplace_bundle">A Marketplace bundle (publish skills + knowledge + procedures)</option>
          <option value="nango_connector">A Nango connector (add support for a new FSM/CRM)</option>
          <option value="platform_skill">A platform skill (cross-tenant capability)</option>
          <option value="super_tenant_integration">A super-tenant integration (cross-tenant tooling)</option>
          <option value="curator_program">Joining the curator program (general enquiry)</option>
          <option value="other">Something else</option>
        </select>
      </label>

      <label class="block">
        <span class="text-sm font-semibold text-[#121621]">Tell us more</span>
        <span class="text-xs text-[#6B7280] block mt-1">What exactly are you planning, who's it for, and how would it be distributed?</span>
        <textarea
          name="details"
          rows="6"
          required
          class="mt-2 block w-full rounded-lg border border-[#E2E8F0] bg-white px-4 py-2.5 text-sm text-[#121621] focus:border-[#0074FF] focus:ring-2 focus:ring-[#0074FF]/20 outline-none transition"
        ></textarea>
      </label>

      <label class="block">
        <span class="text-sm font-semibold text-[#121621]">Existing TrainAR tenant (optional)</span>
        <span class="text-xs text-[#6B7280] block mt-1">If you're already a customer, paste your tenant URL or ID.</span>
        <input
          type="text"
          name="tenant"
          class="mt-2 block w-full rounded-lg border border-[#E2E8F0] bg-white px-4 py-2.5 text-sm text-[#121621] focus:border-[#0074FF] focus:ring-2 focus:ring-[#0074FF]/20 outline-none transition"
        />
      </label>

      <div class="flex items-center gap-4 pt-2">
        <button
          type="submit"
          id="submit-btn"
          class="inline-flex items-center rounded-[12px] px-5 py-3 text-sm font-semibold text-white shadow-[0_4px_20px_hsla(212,100%,50%,0.15)] hover:shadow-[0_8px_30px_hsla(212,100%,50%,0.20)] transition-all disabled:opacity-50 disabled:cursor-not-allowed"
          style="background: linear-gradient(180deg, #0074FF 0%, #005FD1 100%);"
        >
          Submit application
        </button>
        <span id="status-text" class="text-sm text-[#6B7280]"></span>
      </div>
    </form>

    <div id="success-panel" class="hidden mt-10 rounded-2xl border border-[#3BFFBF]/40 bg-[#3BFFBF]/10 p-8">
      <h2 class="font-[var(--font-display)] text-2xl font-bold uppercase tracking-tight text-[#121621]">Application received</h2>
      <p class="mt-3 text-[#4B5563]">We'll be in touch within 3 business days. If you don't hear back by then, drop us a line at <a href="mailto:partners@trainar.ai" class="text-[#0074FF] font-semibold hover:underline">partners@trainar.ai</a>.</p>
    </div>
  </section>

  <script>
    const form = document.getElementById('access-form');
    const successPanel = document.getElementById('success-panel');
    const statusText = document.getElementById('status-text');
    const submitBtn = document.getElementById('submit-btn');

    if (form && successPanel && statusText && submitBtn) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const formEl = e.target as HTMLFormElement;
        const btn = submitBtn as HTMLButtonElement;
        btn.disabled = true;
        statusText.textContent = 'Submitting…';
        statusText.className = 'text-sm text-[#6B7280]';

        const data = Object.fromEntries(new FormData(formEl).entries());

        try {
          const res = await fetch('https://api.trainar.ai/v1/submit-developer-access-request', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          });
          if (!res.ok) throw new Error(`Submit failed (${res.status})`);
          formEl.style.display = 'none';
          successPanel.classList.remove('hidden');
          window.scrollTo({ top: 0, behavior: 'smooth' });
        } catch (err) {
          statusText.textContent = 'Submission failed — please email partners@trainar.ai or try again in a moment.';
          statusText.className = 'text-sm text-red-600';
          btn.disabled = false;
        }
      });
    }
  </script>
</Layout>
